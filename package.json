{
  "name": "talisman",
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39",
  "scripts": {
    "postinstall": "preconstruct dev && pnpm chore:update-translations && pnpm papi:once",
    "prepare": "husky",
    "preconstruct:dev": "preconstruct dev",
    "preconstruct:fix": "preconstruct fix",
    "papi": "papi",
    "papi:once": "test -d .papi/descriptors/dist && echo 'existing papi descriptors found! run \"pnpm papi\" to regenerate them' || papi",
    "papi:update": "papi update",
    "chore:format": "prettier --write \"{apps,config,packages}/**/src/**/*.{ts,tsx,js,jsx,css,scss,html,md,json}\"",
    "chore:update-translations": "pnpm run --filter extension chore:update-translations",
    "chore:update:translations": "pnpm chore:update-translations",
    "update:translations": "pnpm chore:update-translations",
    "chore:generate-init-data": "pnpm run --filter @talismn/chaindata-provider chore:generate-init-data",
    "generate-init-data": "pnpm chore:generate-init-data",
    "dev": "pnpm dev:extension",
    "dev:*": "concurrently --prefix \"{name}\" --prefix-colors auto \"pnpm:dev:*\"",
    "dev:balances-demo": "pnpm run --filter balances-demo dev",
    "dev:extension": "preconstruct dev && pnpm run --filter extension dev",
    "dev:extension:firefox": "preconstruct dev && pnpm run --filter extension dev:firefox",
    "dev:playground": "pnpm run --filter playground dev",
    "build": "turbo run build",
    "build:packages": "NODE_OPTIONS=--max_old_space_size=8192 preconstruct build",
    "build:extension": "turbo run build:extension",
    "build:extension:firefox": "turbo run build:extension:firefox",
    "build:extension:ci": "turbo run build:extension:ci",
    "build:extension:ci:firefox": "turbo run build:extension:ci:firefox",
    "build:extension:canary": "turbo run build:extension:canary",
    "build:extension:canary:firefox": "turbo run build:extension:canary:firefox",
    "build:extension:prod": "turbo run build:extension:prod",
    "build:extension:prod:firefox": "turbo run build:extension:prod:firefox",
    "build:review:firefox": "bash scripts/build-review-firefox.sh",
    "lint": "pnpm run -r --parallel lint",
    "test": "pnpm run -r --parallel test",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e:debug": "pnpm exec playwright test --debug",
    "test:e2e:trace": "pnpm exec playwright test --trace on && pnpm exec playwright show-report",
    "clean": "pnpm run -r --parallel clean & rm -rf dist .turbo node_modules & wait"
  },
  "dependencies": {
    "polkadot-api": "1.9.10"
  },
  "devDependencies": {
    "@alectalisman/preconstruct-cli": "2.3.0-e",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@playwright/test": "^1.51.1",
    "@talismn/eslint-config": "workspace:*",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.9",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "concurrently": "^9.0.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "ts-loader": "9.5.1",
    "turbo": "2.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "react-native",
        "eciesjs"
      ],
      "allowAny": [
        "utf-8-validate",
        "eciesjs"
      ]
    },
    "overrides": {
      "@polkadot-api/merkleize-metadata": "1.1.14",
      "@polkadot-api/metadata-builders": "0.10.2",
      "@polkadot-api/substrate-bindings": "0.11.1",
      "@polkadot-api/utils": "0.1.2",
      "@polkadot/api": "15.8.1",
      "@polkadot/api-augment": "15.8.1",
      "@polkadot/api-base": "15.8.1",
      "@polkadot/api-contract": "15.8.1",
      "@polkadot/api-derive": "15.8.1",
      "@polkadot/apps-config": "0.146.1",
      "@polkadot/extension": "0.56.2",
      "@polkadot/extension-base": "0.56.2",
      "@polkadot/extension-chains": "0.56.2",
      "@polkadot/extension-compat-metamask": "0.56.2",
      "@polkadot/extension-dapp": "0.56.2",
      "@polkadot/extension-inject": "0.56.2",
      "@polkadot/extension-mocks": "0.56.2",
      "@polkadot/extension-ui": "0.56.2",
      "@polkadot/keyring": "13.5.1",
      "@polkadot/networks": "13.5.1",
      "@polkadot/react-identicon": "3.11.3",
      "@polkadot/react-qr": "3.11.3",
      "@polkadot/reactnative-identicon": "3.11.3",
      "@polkadot/rpc-augment": "15.8.1",
      "@polkadot/rpc-core": "15.8.1",
      "@polkadot/rpc-provider": "15.8.1",
      "@polkadot/typegen": "15.8.1",
      "@polkadot/types": "15.8.1",
      "@polkadot/types-augment": "15.8.1",
      "@polkadot/types-codec": "15.8.1",
      "@polkadot/types-create": "15.8.1",
      "@polkadot/types-known": "15.8.1",
      "@polkadot/types-support": "15.8.1",
      "@polkadot/ui-assets": "3.11.3",
      "@polkadot/ui-keyring": "3.11.3",
      "@polkadot/ui-settings": "3.11.3",
      "@polkadot/ui-shared": "3.11.3",
      "@polkadot/util": "13.5.1",
      "@polkadot/util-crypto": "13.5.1",
      "@polkadot/vue-identicon": "3.11.3",
      "@polkadot/wasm-bridge": "7.4.1",
      "@polkadot/wasm-crypto": "7.4.1",
      "@polkadot/wasm-crypto-asmjs": "7.4.1",
      "@polkadot/wasm-crypto-init": "7.4.1",
      "@polkadot/wasm-crypto-wasm": "7.4.1",
      "@polkadot/wasm-util": "7.4.1",
      "@polkadot/x-bigint": "13.5.1",
      "@polkadot/x-bundle": "13.5.1",
      "@polkadot/x-fetch": "13.5.1",
      "@polkadot/x-global": "13.5.1",
      "@polkadot/x-randomvalues": "13.5.1",
      "@polkadot/x-textdecoder": "13.5.1",
      "@polkadot/x-textencoder": "13.5.1",
      "@polkadot/x-ws": "13.5.1",
      "@substrate/txwrapper-core": "7.5.3",
      "@substrate/txwrapper-dev": "7.5.3",
      "@substrate/txwrapper-examples": "7.5.3",
      "@substrate/txwrapper-orml": "7.5.3",
      "@substrate/txwrapper-polkadot": "7.5.3",
      "@substrate/txwrapper-registry": "7.5.3",
      "@substrate/txwrapper-substrate": "7.5.3",
      "@substrate/txwrapper-template": "7.5.3",
      "braces@<3.0.3": ">=3.0.3",
      "caniuse-lite": "1.0.30001669",
      "cookie@<0.7.0": ">=0.7.0",
      "decode-uri-component": "0.2.2",
      "elliptic": ">=6.6.1",
      "glob-parent": "6.0.2",
      "micromatch@<4.0.8": ">=4.0.8",
      "path-to-regexp@>=0.2.0 <1.9.0": ">=1.9.0",
      "rollup@<2.79.2": ">=2.79.2",
      "rollup@>=4.0.0 <4.22.4": ">=4.22.4",
      "secp256k1@>=4.0.0 <4.0.4": ">=4.0.4",
      "semver": "7.6.3",
      "tough-cookie@<4.1.3": ">=4.1.3",
      "undici@<5.26.2": ">=5.26.2",
      "undici@<5.28.4": ">=5.28.4",
      "undici@<=5.28.2": ">=5.28.3",
      "ws@>=7.0.0 <7.5.10": ">=7.5.10",
      "ws@>=8.0.0 <8.17.1": ">=8.17.1",
      "axios@>=1.0.0 <1.8.2": ">=1.8.2",
      "@babel/runtime@<7.26.10": ">=7.26.10",
      "@babel/helpers@<7.26.10": ">=7.26.10",
      "image-size@>=1.1.0 <1.2.1": ">=1.2.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,scss,html,md,json}": "prettier --write",
    "*.{js,ts,jsx,tsx}": "eslint --fix --max-warnings 0"
  },
  "preconstruct": {
    "packages": [
      "packages/*"
    ]
  }
}
